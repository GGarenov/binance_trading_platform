# Copy to .env and fill in real values. .env is gitignored — never commit it.

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://cryptolab:cryptolab@localhost:5432/cryptostrategy_lab"

# Port the Express API listens on
PORT=4000

# No Binance API key is needed for market data, backtests or paper trading —
# public endpoints are keyless.

# Binance Spot TESTNET keys — only needed for live_testnet sessions (real orders,
# fake money). Create them at https://testnet.binance.vision (log in with GitHub).
# Testnet keys can NEVER touch real funds; still, never commit them.
BINANCE_TESTNET_API_KEY=""
BINANCE_TESTNET_API_SECRET=""
